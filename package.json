{
  "name": "soaring-data",
  "version": "0.1.0",
  "description": "Data for soaring, as Frictionless Data Packages: a catalogue of pointers (no airspace is shipped — it goes stale), and the only data that may be shipped because it does not change (landmarks).",
  "license": "AGPL-3.0",
  "type": "module",
  "author": "Sébastien Celles",
  "repository": {
    "type": "git",
    "url": "https://github.com/s-celles/soaring-data.git"
  },
  "keywords": [
    "soaring",
    "gliding",
    "frictionless",
    "datapackage",
    "openair",
    "waypoints",
    "natural-earth"
  ],
  "files": [
    "catalogue",
    "datasets"
  ],
  "scripts": {
    "build": "bun run scripts/build-landmarks.ts",
    "validate": "bun run scripts/validate.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
